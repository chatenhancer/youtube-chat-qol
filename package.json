{
  "name": "youtube-chat-qol",
  "version": "0.7.7",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs --target=chrome",
    "build:chrome": "node scripts/build.mjs --target=chrome",
    "build:edge": "node scripts/build.mjs --target=edge",
    "build:firefox": "node scripts/build.mjs --target=firefox",
    "build:all": "node scripts/build.mjs --all",
    "icons": "node scripts/generate-icons.mjs",
    "screenshots": "node scripts/generate-screenshots.mjs",
    "docs:commands": "node scripts/sync-command-docs.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "verify": "npm run typecheck && npm run lint && npm run build:all",
    "zip": "npm run build && node scripts/zip.mjs",
    "zip:chrome": "npm run build:chrome && node scripts/zip.mjs --target=chrome",
    "zip:edge": "npm run build:edge && node scripts/zip.mjs --target=edge",
    "zip:firefox": "npm run build:firefox && node scripts/zip.mjs --target=firefox",
    "zip:all": "npm run build:all && node scripts/zip.mjs --all",
    "release:validate-tag": "node scripts/validate-release-tag.mjs",
    "release:chrome": "node scripts/submit-chrome-webstore.mjs",
    "release:firefox": "node scripts/submit-firefox-amo.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/chrome": "^0.0.315",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "globals": "^16.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
