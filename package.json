{
  "name": "youtube-chat-qol",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run generate && npm run build:extensions",
    "build:chrome": "npm run generate && node scripts/build.mjs --target=chrome",
    "build:edge": "npm run generate && node scripts/build.mjs --target=edge",
    "build:firefox": "npm run generate && node scripts/build.mjs --target=firefox",
    "build:extensions": "node scripts/build.mjs --all",
    "build:all": "npm run build",
    "generate": "npm run icons && npm run screenshots",
    "icons": "node scripts/generate-icons.mjs",
    "screenshots": "npm run docs:build && node scripts/generate-dom-screenshots.mjs",
    "screenshots:dom": "npm run screenshots",
    "docs:build": "npm run docs:validate-locales && node scripts/build-docs-locales.mjs",
    "docs:validate-locales": "node scripts/validate-docs-locales.mjs",
    "locales": "node scripts/sync-extension-locales.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint",
    "verify": "npm run check && npm run build",
    "zip": "npm run verify && node scripts/zip.mjs",
    "zip:chrome": "npm run check && npm run build:chrome && node scripts/zip.mjs --target=chrome",
    "zip:edge": "npm run check && npm run build:edge && node scripts/zip.mjs --target=edge",
    "zip:firefox": "npm run check && npm run build:firefox && node scripts/zip.mjs --target=firefox",
    "zip:all": "npm run verify && node scripts/zip.mjs --all",
    "cloudflare:dev": "npx wrangler@4 dev --config cloudflare/wrangler.toml",
    "cloudflare:deploy": "npx wrangler@4 deploy --config cloudflare/wrangler.toml",
    "release:validate-tag": "node scripts/validate-release-tag.mjs",
    "release:chrome": "node scripts/submit-chrome-webstore.mjs",
    "release:firefox": "node scripts/submit-firefox-amo.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/chrome": "^0.0.315",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "globals": "^16.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
