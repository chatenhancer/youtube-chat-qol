{
  "name": "youtube-chat-qol",
  "version": "0.14.7",
  "private": true,
  "license": "GPL-3.0-or-later",
  "browser": {
    "fs": false,
    "path": false,
    "readline": false,
    "worker_threads": false
  },
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs --all",
    "build:chrome": "node scripts/build.mjs --target=chrome",
    "build:chrome:playground-local": "node scripts/build.mjs --target=chrome --playground-backend=http://127.0.0.1:8787",
    "build:edge": "node scripts/build.mjs --target=edge",
    "build:firefox": "node scripts/build.mjs --target=firefox",
    "build:firefox:playground-local": "node scripts/build.mjs --target=firefox --playground-backend=http://127.0.0.1:8787",
    "build:playground-local": "npm run build:chrome:playground-local && npm run build:firefox:playground-local",
    "docs:screenshots": "npm run docs:build && node scripts/generate-dom-screenshots.mjs",
    "docs:dev": "astro dev --config astro.docs.config.mjs --force",
    "docs:check": "astro check --config astro.docs.config.mjs",
    "docs:build": "node scripts/validate-docs-locales.mjs && astro build --config astro.docs.config.mjs --force",
    "docs:preview": "npm run docs:build && astro preview --config astro.docs.config.mjs",
    "zip": "npm run verify && node scripts/zip.mjs --all",
    "cloudflare:check": "npm run cloudflare:language-redirect:check && npm run cloudflare:playground:check",
    "cloudflare:language-redirect:check": "cross-env WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --config cloudflare/language-redirect/wrangler.toml --dry-run",
    "cloudflare:language-redirect:dev": "cross-env WRANGLER_LOG_PATH=.wrangler/logs wrangler dev --config cloudflare/language-redirect/wrangler.toml",
    "cloudflare:language-redirect:deploy": "cross-env WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --config cloudflare/language-redirect/wrangler.toml",
    "cloudflare:playground:check": "cross-env WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --config cloudflare/playground/wrangler.toml --dry-run --containers-rollout=none",
    "cloudflare:playground:check:containers": "cross-env WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --config cloudflare/playground/wrangler.toml --dry-run",
    "cloudflare:playground:dev": "cross-env WRANGLER_LOG_PATH=.wrangler/logs wrangler dev --config cloudflare/playground/wrangler.toml",
    "cloudflare:playground:deploy": "cross-env WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --config cloudflare/playground/wrangler.toml",
    "demo:walkthrough": "npm run build:chrome && node scripts/capture-walkthrough-demo.mjs",
    "demo:walkthrough:preview": "npm run build:chrome && node scripts/capture-walkthrough-demo.mjs --preview",
    "postinstall": "node scripts/install-playwright-browser.mjs",
    "publish:chrome": "node scripts/submit-chrome-webstore.mjs",
    "publish:chrome:deferred": "node scripts/publish-deferred-chrome-webstore.mjs",
    "publish:firefox": "node scripts/submit-firefox-amo.mjs",
    "test": "node scripts/run-unit-tests.mjs",
    "test:browser": "node scripts/run-browser-tests.mjs",
    "test:browser:flake": "node scripts/run-browser-flake-tests.mjs",
    "test:browser:install": "playwright install chromium",
    "test:browser:install-deps": "playwright install --with-deps chromium",
    "test:browser:live": "node scripts/run-browser-tests.mjs --project=youtube-live",
    "test:browser:mock": "node scripts/run-browser-tests.mjs --project=youtube-mock",
    "test:browser:perf": "node scripts/run-browser-performance-tests.mjs",
    "test:coverage": "node scripts/run-unit-tests.mjs --coverage && node scripts/write-coverage-notice.mjs && node scripts/generate-readme-badges.mjs",
    "test:youtube-login": "node scripts/open-youtube-test-profile.mjs",
    "test:watch": "vitest",
    "ci:install-playwright": "npm run test:browser:install",
    "ci:pages-build": "npm run docs:build",
    "version:bump": "node scripts/bump-version.mjs",
    "release:tag": "node scripts/create-release-tag.mjs",
    "ci:release-validate-tag": "node scripts/validate-release-tag.mjs",
    "ci:test-browser-gate": "node scripts/run-browser-tests.mjs --no-build tests/browser/specs/yt-mock-logged-in.spec.ts tests/browser/specs/yt-mock-logged-out.spec.ts tests/browser/specs/yt-mock-replay.spec.ts tests/browser/specs/yt-live-logged-out.spec.ts",
    "ci:browser-artifacts": "node scripts/collect-mock-browser-artifacts.mjs",
    "ci:test-summary": "node scripts/write-ci-test-summary.mjs",
    "ci:verify": "npm run check && npm run test:coverage && npm run build && npm run cloudflare:check && npm run ci:test-browser-gate",
    "typecheck": "npm run typecheck:extension && npm run typecheck:cloudflare",
    "typecheck:extension": "tsc --noEmit -p tsconfig.json",
    "typecheck:cloudflare": "tsc --noEmit -p cloudflare/tsconfig.json",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint && npm run docs:check",
    "verify": "npm run ci:verify"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260615.1",
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.315",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "astro": "^6.4.6",
    "cross-env": "^7.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.27.0",
    "globals": "^16.1.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^4.1.7",
    "wrangler": "^4.100.0"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.7",
    "chess.js": "^1.4.0"
  }
}
