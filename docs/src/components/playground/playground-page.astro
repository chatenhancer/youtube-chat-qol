---
import Icon from '../common/icon.astro';

interface PlaygroundGame {
  alt: string;
  body: string;
  href: string;
  image: string;
  imageHeight: number;
  imageWidth: number;
  title: string;
}

interface PlaygroundPageCopy {
  computerBody: string;
  computerTitle: string;
  exploreCta: string;
  gamesHeadingFirst: string;
  gamesHeadingSecond: string;
  introFirst: string;
  introSecond: string;
  logoAlt: string;
  primaryCta: string;
  readyTitle: string;
  seeHow: string;
  settingsAlt: string;
  taglineLead: string;
  taglineTail: string;
}

const { computerHref, copy, games, installHref } = Astro.props as {
  computerHref: string;
  copy: PlaygroundPageCopy;
  games: PlaygroundGame[];
  installHref: string;
};

const gameLogoPattern = [
  { className: 'pg-logo-chess', kind: 'chess' },
  { className: 'pg-logo-wild', kind: 'image', src: '/assets/playground/wild-wild-chat-logo.webp' },
  { className: 'pg-logo-stick', kind: 'image', src: '/assets/playground/stick-around-logo.webp' },
  { className: 'pg-logo-trivia', kind: 'image', src: '/assets/playground/replay-trivia-logo.png' }
] as const;
const marqueeGameLogos = Array.from({ length: 3 }, () => gameLogoPattern).flat();
---

<div class="pg-landing">
  <section class="pg-hero" aria-labelledby="pg-title">
    <div class="pg-hero-inner">
      <h1 id="pg-title">
        <img
          class="pg-title-logo"
          src="/assets/playground/playground-logo.svg"
          alt={copy.logoAlt}
          width="1746"
          height="457"
          decoding="async"
        >
      </h1>

      <div class="pg-tagline-rail">
        <div class="pg-logo-window pg-logo-window-left" aria-hidden="true">
          <div class="pg-logo-track">
            {[0, 1].map(() => (
              <div class="pg-logo-sequence">
                {marqueeGameLogos.map((logo) => (
                  logo.kind === 'chess' ? (
                    <span class="pg-logo-chess"><span class="pg-logo-chess-piece"></span></span>
                  ) : (
                    <img class={logo.className} src={logo.src} alt="" decoding="async">
                  )
                ))}
              </div>
            ))}
          </div>
        </div>
        <p class="pg-tagline"><strong>{copy.taglineLead}</strong><span>{copy.taglineTail}</span></p>
        <div class="pg-logo-window pg-logo-window-right" aria-hidden="true">
          <div class="pg-logo-track">
            {[0, 1].map(() => (
              <div class="pg-logo-sequence">
                {marqueeGameLogos.map((logo) => (
                  logo.kind === 'chess' ? (
                    <span class="pg-logo-chess"><span class="pg-logo-chess-piece"></span></span>
                  ) : (
                    <img class={logo.className} src={logo.src} alt="" decoding="async">
                  )
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>

      <p class="pg-intro">
        <span>{copy.introFirst}</span>
        <span>{copy.introSecond}</span>
      </p>
      <div class="pg-hero-actions">
        <a class="button button-primary" href={installHref}>
          <span class="button-icon" aria-hidden="true"><Icon name="extension" /></span>
          {copy.primaryCta}
        </a>
        <a class="button pg-button-secondary" href="#pg-games-title">{copy.exploreCta}</a>
      </div>
    </div>
  </section>

  <section class="pg-games" id="games" aria-labelledby="pg-games-title">
    <div class="pg-games-inner">
      <h2 id="pg-games-title">{copy.gamesHeadingFirst}<br>{copy.gamesHeadingSecond}</h2>

      <div class="pg-game-list">
        {games.map((game, index) => (
          <article class:list={['pg-game', { 'pg-game-reverse': index % 2 === 1 }]}>
            <div class="pg-game-copy">
              <h3>{game.title}</h3>
              <p>{game.body}</p>
              <a href={game.href}>
                {copy.seeHow}
                <span class="pg-link-arrow" aria-hidden="true"><span>→</span></span>
              </a>
            </div>
            <div class="pg-game-art">
              <img
                class="pg-game-image"
                src={game.image}
                alt={game.alt}
                width={game.imageWidth}
                height={game.imageHeight}
                loading="lazy"
                decoding="async"
              >
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="pg-computer" aria-labelledby="pg-computer-title">
    <div class="pg-computer-inner">
      <img
        class="pg-settings-image"
        src="/assets/playground/page/settings.png"
        alt={copy.settingsAlt}
        width="686"
        height="654"
        loading="lazy"
        decoding="async"
      >
      <div class="pg-computer-copy">
        <h2 id="pg-computer-title">{copy.computerTitle}</h2>
        <p>{copy.computerBody}</p>
        <a href={computerHref}>
          {copy.seeHow}
          <span class="pg-link-arrow" aria-hidden="true"><span>→</span></span>
        </a>
      </div>
    </div>

    <div class="pg-ready">
      <div class="pg-logo-rail pg-logo-rail-ready" aria-hidden="true">
        {gameLogoPattern.map((logo) => (
          logo.kind === 'chess' ? (
            <span class="pg-logo-chess"><span class="pg-logo-chess-piece"></span></span>
          ) : (
            <img class={logo.className} src={logo.src} alt="" loading="lazy" decoding="async">
          )
        ))}
      </div>
      <h2>{copy.readyTitle}</h2>
      <a class="button pg-ready-button" href={installHref}>
        <span class="button-icon" aria-hidden="true"><Icon name="extension" /></span>
        <span class="pg-ready-button-label">{copy.primaryCta}</span>
      </a>
    </div>
  </section>
</div>

<style>
  .pg-landing {
    --pg-blue: #5eaff2;
    --pg-blue-deep: #2994ef;
    color: #16171b;
    background: #fff;
  }

  .pg-hero {
    min-height: 580px;
    display: grid;
    place-items: center;
    padding: 86px 24px 68px;
    overflow: hidden;
    text-align: center;
  }

  .pg-hero-inner {
    display: grid;
    justify-items: center;
    width: min(1040px, 100%);
  }

  .pg-hero h1 {
    width: min(760px, 100%);
    margin: 0;
    line-height: 0;
  }

  .pg-title-logo {
    display: block;
    width: 100%;
    height: auto;
  }

  .pg-tagline-rail {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(16px, 3vw, 42px);
    width: 100vw;
    margin: 10px calc(50% - 50vw) 26px;
  }

  .pg-tagline {
    display: grid;
    justify-items: center;
    margin: 0;
    color: #31343a;
    font-size: clamp(18px, 2.3vw, 26px);
    line-height: 1.05;
  }

  .pg-tagline strong {
    color: var(--pg-blue-deep);
    font-family: var(--font-playground);
    font-size: 1.45em;
    font-weight: 400;
    letter-spacing: 0;
    transform: rotate(-4deg);
  }

  .pg-tagline > span {
    letter-spacing: -0.025em;
  }

  .pg-logo-rail,
  .pg-logo-sequence,
  .pg-logo-track,
  .pg-logo-window {
    display: flex;
    align-items: center;
  }

  .pg-logo-rail {
    justify-content: center;
  }

  .pg-logo-window {
    min-width: 0;
    height: 48px;
    overflow: hidden;
    direction: ltr;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent);
    opacity: 0.34;
  }

  .pg-logo-window-left,
  .pg-logo-window-right {
    justify-content: flex-start;
  }

  .pg-logo-track {
    --pg-logo-gap: clamp(32px, 4vw, 58px);
    flex: 0 0 max-content;
    width: max-content;
    will-change: transform;
  }

  .pg-logo-sequence {
    flex: 0 0 auto;
    gap: var(--pg-logo-gap);
    padding-right: var(--pg-logo-gap);
  }

  .pg-logo-window-left .pg-logo-track {
    animation: pg-logo-scroll-left 18s linear infinite;
  }

  .pg-logo-window-right .pg-logo-track {
    animation: pg-logo-scroll-right 18s linear infinite;
  }

  @keyframes pg-logo-scroll-left {
    to {
      transform: translateX(-50%);
    }
  }

  @keyframes pg-logo-scroll-right {
    from {
      transform: translateX(-50%);
    }

    to {
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pg-logo-track {
      animation: none !important;
      transform: none !important;
    }

    .pg-game-art {
      animation: none !important;
    }

    .pg-ready-button,
    .pg-ready-button::before {
      transition: none !important;
    }

    .pg-game-copy a:hover .pg-link-arrow,
    .pg-game-copy a:focus .pg-link-arrow,
    .pg-computer-copy a:hover .pg-link-arrow,
    .pg-computer-copy a:focus .pg-link-arrow {
      animation: none !important;
      transform: translateX(4px);
      transition-delay: 0ms;
    }

    .pg-game-copy a:hover .pg-link-arrow > span,
    .pg-game-copy a:focus .pg-link-arrow > span,
    .pg-computer-copy a:hover .pg-link-arrow > span,
    .pg-computer-copy a:focus .pg-link-arrow > span {
      animation: none !important;
    }
  }

  .pg-logo-rail img,
  .pg-logo-track img {
    display: block;
    flex: 0 0 auto;
    width: auto;
    object-fit: contain;
  }

  .pg-logo-track img {
    max-width: 62px;
    height: 29px;
  }

  .pg-logo-rail .pg-logo-trivia,
  .pg-logo-track .pg-logo-trivia {
    max-width: 72px;
  }

  .pg-logo-chess {
    position: relative;
    display: block;
    flex: 0 0 36px;
    width: 36px;
    height: 36px;
    image-rendering: pixelated;
  }

  .pg-logo-chess-piece {
    position: absolute;
    display: block;
    left: 2px;
    top: 2px;
    width: 32px;
    height: 32px;
    background-image: url('/assets/playground/chess-white-pieces.png');
    background-repeat: no-repeat;
    background-position: -32px 0;
    background-size: 64px 96px;
    image-rendering: pixelated;
  }

  .pg-intro {
    max-width: 760px;
    margin: 0;
    color: #555a64;
    font-size: 17px;
    line-height: 1.55;
  }

  .pg-intro span {
    display: block;
  }

  .pg-hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 28px;
  }

  .pg-hero-actions .button,
  .pg-ready-button {
    min-height: 42px;
    padding: 9px 15px;
    font-size: 14px;
  }

  .pg-button-secondary {
    color: #272a31;
    background: #fff;
    border-color: #d9dee7;
  }

  .pg-games {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    background: linear-gradient(
      180deg,
      #fff 0%,
      #f6fbff 1%,
      #d6ebfb 2.5%,
      #97ccf7 4%,
      #67b5f4 5.5%,
      #2e96ed 94.5%,
      #73b6f3 96%,
      #aed7f7 97.5%,
      #edf7fe 99%,
      #fff 100%
    );
  }

  .pg-games::before {
    content: "";
    position: absolute;
    z-index: 0;
    inset: 0;
    pointer-events: none;
    /* CC0 cloud alpha by WickedInsignia: opengameart.org/content/clouds-with-transparency */
    background: url('/assets/playground/page/cloud-overlay.webp') center 2% / min(1180px, 108vw) auto repeat-y;
    filter: brightness(0) invert(1);
    -webkit-mask-image: linear-gradient(180deg, transparent, #000 7%, #000 93%, transparent);
    mask-image: linear-gradient(180deg, transparent, #000 7%, #000 93%, transparent);
    opacity: 0.25;
  }

  .pg-games::after {
    content: "";
    position: absolute;
    z-index: 0;
    inset: 0;
    pointer-events: none;
    background: url('/assets/playground/page/cloud-overlay.webp') left -320px top 520px / 920px auto repeat-y;
    filter: brightness(0) invert(1);
    -webkit-mask-image: linear-gradient(180deg, transparent, #000 7%, #000 93%, transparent);
    mask-image: linear-gradient(180deg, transparent, #000 7%, #000 93%, transparent);
    opacity: 0.13;
    transform: scaleX(-1);
  }

  .pg-games-inner {
    position: relative;
    z-index: 1;
    width: min(1080px, calc(100% - 48px));
    margin: 0 auto;
    padding: 260px 0 280px;
  }

  .pg-games h2 {
    max-width: none;
    margin: 0 0 62px;
    color: #fff;
    text-align: center;
    font-size: clamp(40px, 5vw, 66px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.055em;
    scroll-margin-top: calc(var(--header-scroll-offset) + 88px);
  }

  .pg-game-list {
    display: grid;
    gap: clamp(72px, 9vw, 118px);
  }

  .pg-game {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.1fr);
    gap: clamp(38px, 7vw, 92px);
    align-items: center;
  }

  .pg-game-reverse .pg-game-copy {
    order: 2;
  }

  .pg-game-reverse .pg-game-art {
    order: 1;
  }

  .pg-game-copy {
    justify-self: center;
    max-width: 470px;
  }

  .pg-game-copy h3 {
    margin: 0 0 13px;
    color: #fff;
    font-family: var(--font-title);
    font-size: clamp(34px, 3.8vw, 52px);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.045em;
    text-shadow:
      0 5.45px 73.88px rgba(255, 255, 255, 0.44),
      0 0 20px rgba(255, 255, 255, 0.28);
  }

  .pg-game-copy p {
    margin: 0 0 18px;
    color: rgba(255, 255, 255, 0.95);
    font-size: clamp(19px, 2vw, 24px);
    line-height: 1.5;
  }

  .pg-game-copy a,
  .pg-computer-copy a {
    display: inline-flex;
    align-items: center;
    gap: 0.16em;
    color: inherit;
    font-size: 19px;
    font-weight: 800;
    text-decoration: none;
  }

  .pg-game-copy a:hover,
  .pg-game-copy a:focus,
  .pg-computer-copy a:hover,
  .pg-computer-copy a:focus {
    text-decoration: none;
  }

  .pg-link-arrow {
    display: inline-flex;
    transform: translateX(0);
    transition: transform 180ms ease-out;
    transition-delay: 0ms;
  }

  .pg-link-arrow > span {
    display: block;
    transform-origin: center;
  }

  .pg-game-copy a:hover .pg-link-arrow,
  .pg-game-copy a:focus .pg-link-arrow,
  .pg-computer-copy a:hover .pg-link-arrow,
  .pg-computer-copy a:focus .pg-link-arrow {
    transform: translateX(5px);
    transition-delay: 540ms;
  }

  .pg-game-copy a:hover .pg-link-arrow > span,
  .pg-game-copy a:focus .pg-link-arrow > span,
  .pg-computer-copy a:hover .pg-link-arrow > span,
  .pg-computer-copy a:focus .pg-link-arrow > span {
    animation: pg-link-arrow-spin 620ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .pg-game-art {
    justify-self: center;
    width: min(100%, 520px);
    animation: pg-card-float 6.2s ease-in-out infinite;
    backface-visibility: hidden;
    transform-origin: center;
    will-change: transform;
  }

  .pg-game-image {
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 24px rgba(12, 64, 118, 0.2));
  }

  .pg-game:nth-child(2) .pg-game-art {
    animation-delay: -2.1s;
    animation-duration: 6.8s;
    width: min(100%, 526px);
  }

  .pg-game:nth-child(3) .pg-game-art {
    animation-delay: -4.2s;
    animation-duration: 6.5s;
    width: min(100%, 536px);
  }

  .pg-game:nth-child(4) .pg-game-art {
    animation-delay: -1.1s;
    animation-duration: 7.1s;
  }

  @keyframes pg-card-float {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }

    50% {
      transform: translate3d(0, -12px, 0);
    }
  }

  @keyframes pg-link-arrow-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (min-width: 821px) {
    .pg-game-reverse {
      grid-template-columns: minmax(360px, 1.1fr) minmax(0, 0.9fr);
    }

    .pg-game:last-child {
      grid-template-columns: minmax(420px, 1.2fr) minmax(0, 0.8fr);
    }

    .pg-game:last-child .pg-game-art {
      width: min(100%, 580px);
    }
  }

  .pg-computer {
    padding: 112px 24px 92px;
    background: #fff;
  }

  .pg-computer-inner {
    display: grid;
    grid-template-columns: minmax(320px, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(42px, 7vw, 94px);
    align-items: center;
    width: min(980px, 100%);
    margin: 0 auto;
  }

  .pg-settings-image {
    display: block;
    width: min(100%, 500px);
    height: auto;
    transform: rotate(-7deg);
  }

  .pg-computer-copy {
    max-width: 470px;
  }

  .pg-computer-copy h2,
  .pg-ready h2 {
    max-width: none;
    color: #111216;
    font-family: var(--font-title);
    font-weight: 750;
    letter-spacing: -0.055em;
  }

  .pg-computer-copy h2 {
    margin: 0 0 20px;
    font-size: clamp(40px, 5vw, 60px);
    line-height: 1.02;
    letter-spacing: -0.045em;
  }

  .pg-computer-copy p {
    margin: 0 0 20px;
    color: #60636b;
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: 1.6;
  }

  .pg-ready {
    display: grid;
    justify-items: center;
    margin-top: 108px;
    text-align: center;
  }

  .pg-logo-rail-ready {
    gap: 22px;
    min-height: 38px;
    margin-bottom: 24px;
    opacity: 0.5;
  }

  .pg-logo-rail-ready img {
    max-width: 70px;
    height: 30px;
  }

  .pg-ready h2 {
    margin: 0 0 24px;
    font-size: clamp(42px, 5vw, 62px);
    line-height: 1;
  }

  .pg-ready-button {
    position: relative;
    isolation: isolate;
    justify-content: center;
    min-height: 58px;
    margin-top: 10px;
    padding: 14px 25px;
    overflow: hidden;
    color: var(--logo-red-end);
    background: #fff;
    border: 2px solid var(--logo-red-end);
    border-radius: 22px;
    corner-shape: superellipse(2.4);
    font-size: 16px;
    transition:
      color 180ms ease 100ms,
      transform 260ms ease;
  }

  .pg-ready-button::before {
    content: "";
    position: absolute;
    z-index: -1;
    inset: -2px;
    background: var(--logo-red-end);
    clip-path: circle(0% at 50% 120%);
    transition: clip-path 540ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .pg-ready-button .button-icon,
  .pg-ready-button-label {
    position: relative;
    z-index: 1;
  }

  .pg-ready-button:hover,
  .pg-ready-button:focus {
    color: #fff;
    background: #fff;
    transform: translateY(-3px) scale(1.02);
  }

  .pg-ready-button:hover::before,
  .pg-ready-button:focus::before {
    clip-path: circle(150% at 50% 120%);
  }

  @media (max-width: 820px) {
    .pg-hero {
      min-height: 530px;
      padding-top: 68px;
    }

    .pg-game,
    .pg-computer-inner {
      grid-template-columns: 1fr;
    }

    .pg-game {
      gap: 34px;
    }

    .pg-games-inner {
      padding: 220px 0 250px;
    }

    .pg-game-reverse .pg-game-copy,
    .pg-game-reverse .pg-game-art {
      order: initial;
    }

    .pg-game-copy {
      justify-self: start;
      max-width: 620px;
    }

    .pg-game-art {
      width: min(100%, 470px);
    }

    .pg-game:nth-child(2) .pg-game-art {
      width: min(100%, 475px);
    }

    .pg-game:nth-child(3) .pg-game-art {
      width: min(100%, 485px);
    }

    .pg-game:nth-child(2n) .pg-game-art {
      justify-self: end;
    }

    .pg-game:last-child .pg-game-art {
      width: min(100%, 540px);
    }

    .pg-settings-image {
      justify-self: center;
      width: min(82vw, 500px);
    }

    .pg-computer-copy {
      justify-self: center;
      max-width: 620px;
    }
  }

  @media (max-width: 540px) {
    .pg-hero {
      min-height: 500px;
      padding: 56px 20px 50px;
    }

    .pg-tagline-rail {
      gap: 10px;
      margin-top: 6px;
      margin-bottom: 22px;
    }

    .pg-tagline {
      font-size: 16px;
    }

    .pg-logo-track {
      --pg-logo-gap: 28px;
    }

    .pg-logo-window-left .pg-logo-track,
    .pg-logo-window-right .pg-logo-track {
      animation-duration: 12s;
    }

    .pg-logo-track img {
      max-width: 48px;
      height: 24px;
    }

    .pg-logo-window {
      height: 38px;
    }

    .pg-logo-window .pg-logo-chess {
      transform: scale(0.8);
    }

    .pg-intro {
      font-size: 15px;
    }

    .pg-intro span {
      display: inline;
    }

    .pg-intro span + span::before {
      content: " ";
    }

    .pg-hero-actions {
      width: 100%;
    }

    .pg-hero-actions .button {
      justify-content: center;
      width: 100%;
    }

    .pg-games-inner {
      width: min(100% - 40px, 1080px);
      padding: 190px 0 230px;
    }

    .pg-games h2 {
      margin-bottom: 50px;
      font-size: 40px;
    }

    .pg-game-list {
      gap: 72px;
    }

    .pg-game-copy h3 {
      font-size: 36px;
