---
import Icon from '../common/icon.astro';
import type { Messages } from '../../data/site';

const { messages: m } = Astro.props as { messages: Messages };

const timezoneAliases = ['utc', 'tokyo', 'jst', 'seoul', 'kst', 'london', 'paris', 'madrid', 'newyork', 'nyc', 'et', 'eastern', 'losangeles', 'la', 'pt', 'pacific'];
const inlineLabel = m.commands.inlineTitle.replace(/:$/, '');
const wholeInputLabel = m.commands.wholeTitle.replace(/:$/, '');
const commandSections = [
  {
    title: m.commands.textCommandsTitle,
    commands: [
      { command: '/mention', aliases: ['/m', '/reply', '/r'], description: m.commands.mentionDescription, template: '/mention', mode: inlineLabel },
      { command: '/quote', aliases: ['/q'], description: m.commands.quoteDescription, template: '/quote', mode: wholeInputLabel },
      { command: '/again', aliases: ['/repeat'], description: m.commands.repeatDescription, template: '/again', mode: wholeInputLabel },
      { command: '/focus', aliases: ['/f'], description: m.commands.focusDescription, template: '/focus @handle', mode: wholeInputLabel },
      { command: '/who', aliases: [], description: m.commands.whoDescription, template: '/who @handle', mode: wholeInputLabel },
      { command: '/help', aliases: [], description: m.commands.helpDescription, template: '/help', mode: wholeInputLabel }
    ]
  },
  {
    title: m.commands.inboxCommandsTitle,
    commands: [
      { command: '/watch', aliases: ['/w'], description: m.commands.watchDescription, template: '/watch keyword', mode: wholeInputLabel },
      { command: '/unwatch', aliases: ['/uw'], description: m.commands.unwatchDescription, template: '/unwatch keyword', mode: wholeInputLabel }
    ]
  },
  {
    title: m.commands.timeTranslationCommandsTitle,
    commands: [
      { command: '/time', aliases: ['/t'], description: m.commands.timeDescription, detail: `${m.commands.timeAliases} ${timezoneAliases.join(', ')}`, template: '/time utc', mode: inlineLabel },
      { command: '/when', aliases: ['/wh', '/timeuntil', '/tu', '/timesince', '/ts'], description: m.commands.whenDescription, detail: `${m.commands.timeZoneAliases} ${timezoneAliases.join(', ')}`, template: '/when 2026-06-12 19:00 london', mode: inlineLabel },
      { command: '/translate', aliases: ['/tr'], description: m.commands.translateDescription, template: '/translate es hello', mode: inlineLabel }
    ]
  },
  {
    title: m.commands.settingCommandsTitle,
    commands: [
      { command: '/settranslateto', aliases: ['/lang'], description: m.commands.setTranslateDescription, template: '/settranslateto english', mode: wholeInputLabel },
      { command: '/settranslationdisplay', aliases: [], description: m.commands.setDisplayDescription, template: '/settranslationdisplay below', mode: wholeInputLabel },
      { command: '/setsound', aliases: [], description: m.commands.setSoundDescription, template: '/setsound on', mode: wholeInputLabel }
    ]
  }
];
const demoCommands = commandSections.flatMap((section) => section.commands.map((command) => ({ ...command, section: section.title })));
const defaultCommand = demoCommands.find(({ command }) => command === '/translate') || demoCommands[0];
const defaultCommandIndex = Math.max(0, demoCommands.findIndex(({ command }) => command === defaultCommand.command));
const nextCommand = demoCommands[(defaultCommandIndex + 1) % demoCommands.length] || defaultCommand;
---

<section class="section commands" id="commands" aria-labelledby="commands-title">
  <div class="section-inner">
    <span class="section-icon" data-symbol="terminal" aria-hidden="true">
      <Icon name="terminal" />
    </span>
    <p class="eyebrow">{m.commands.eyebrow}</p>
    <h2 id="commands-title">{m.commands.title}</h2>
    <p class="section-copy">{m.commands.copy}</p>

    <div class="command-showcase" data-command-demo>
      <div class="command-playground">
        <div class="command-menu" id="command-demo-menu" data-command-menu role="listbox" aria-label={m.commands.title}>
          {demoCommands.map((item) => (
            <button
              class:list={['command-menu-item', item.command === defaultCommand.command && 'is-active']}
              type="button"
              role="option"
              aria-selected={item.command === defaultCommand.command ? 'true' : 'false'}
              data-command-option
              data-command-value={item.command}
              data-command-template={item.template}
              data-command-description={item.description}
              data-command-search={`${item.command} ${item.aliases.join(' ')} ${item.template} ${item.description} ${item.detail || ''}`.toLowerCase()}
              tabindex={item.command === defaultCommand.command ? '0' : '-1'}
            >
              <span class="command-menu-command">
                <code>{item.command}</code>
                {item.aliases.slice(0, 2).map((alias) => <code class="command-alias-code">{alias}</code>)}
              </span>
              <span class="command-menu-copy">
                <strong>{item.section}</strong>
                <span>{item.description}</span>
              </span>
            </button>
          ))}
        </div>
        <div class="command-composer">
          <div class="command-input-wrap" data-command-input-wrap>
            <input
              id="command-demo-input"
              data-command-input
              value={defaultCommand.template}
              placeholder={defaultCommand.template}
              autocomplete="off"
              spellcheck="false"
              aria-label={m.commands.title}
              aria-controls="command-demo-menu"
              aria-autocomplete="list"
            >
            <span class="command-input-cycle" data-command-cycle aria-hidden="true">
              <span data-command-cycle-current>{defaultCommand.template}</span>
              <span data-command-cycle-next>{nextCommand.template}</span>
            </span>
          </div>
          <span class="command-tab-hint" data-command-tab-hint>Press Tab</span>
        </div>
      </div>
    </div>
  </div>
</section>
