---
import Icon from '../common/icon.astro';
import WalkthroughClipTag from '../common/walkthrough-clip-tag.astro';
import type { Messages } from '../../data/site';

const { messages: m } = Astro.props as { messages: Messages };

const timezoneAliases = ['utc', 'tokyo', 'jst', 'seoul', 'kst', 'london', 'paris', 'madrid', 'newyork', 'nyc', 'et', 'eastern', 'losangeles', 'la', 'pt', 'pacific'];
const inlineLabel = m.commands.inlineTitle.replace(/:$/, '');
const wholeInputLabel = m.commands.wholeTitle.replace(/:$/, '');
const commandSections = [
  {
    title: m.commands.textCommandsTitle,
    commands: [
      { command: '/mention', aliases: ['/m', '/reply', '/r'], description: m.commands.mentionDescription, template: '/mention', mode: inlineLabel },
      { command: '/quote', aliases: ['/q'], description: m.commands.quoteDescription, template: '/quote', mode: wholeInputLabel },
      { command: '/again', aliases: ['/repeat'], description: m.commands.repeatDescription, template: '/again', mode: wholeInputLabel },
      { command: '/focus', aliases: ['/f'], description: m.commands.focusDescription, template: '/focus @handle', mode: wholeInputLabel },
      { command: '/who', aliases: [], description: m.commands.whoDescription, template: '/who @handle', mode: wholeInputLabel },
      { command: '/help', aliases: [], description: m.commands.helpDescription, template: '/help', mode: wholeInputLabel }
    ]
  },
  {
    title: m.commands.inboxCommandsTitle,
    commands: [
      { command: '/watch', aliases: ['/w'], description: m.commands.watchDescription, template: '/watch keyword', mode: wholeInputLabel },
      { command: '/unwatch', aliases: ['/uw'], description: m.commands.unwatchDescription, template: '/unwatch keyword', mode: wholeInputLabel }
    ]
  },
  {
    title: m.commands.timeTranslationCommandsTitle,
    commands: [
      { command: '/time', aliases: ['/t'], description: m.commands.timeDescription, detail: `${m.commands.timeAliases} ${timezoneAliases.join(', ')}`, template: '/time utc', mode: inlineLabel },
      { command: '/when', aliases: ['/wh', '/timeuntil', '/tu', '/timesince', '/ts'], description: m.commands.whenDescription, detail: `${m.commands.timeZoneAliases} ${timezoneAliases.join(', ')}`, template: '/when 2026-06-12 19:00 london', mode: inlineLabel },
      { command: '/translate', aliases: ['/tr'], description: m.commands.translateDescription, template: '/translate es hello', mode: inlineLabel }
    ]
  },
  {
    title: m.commands.settingCommandsTitle,
    commands: [
      { command: '/lang', aliases: [], description: m.commands.setTranslateDescription, template: '/lang english', mode: wholeInputLabel },
      { command: '/display', aliases: [], description: m.commands.setDisplayDescription, template: '/display below', mode: wholeInputLabel },
      { command: '/mute', aliases: [], description: m.commands.setSoundDescription, template: '/mute', mode: wholeInputLabel },
      { command: '/unmute', aliases: [], description: m.commands.setSoundDescription, template: '/unmute', mode: wholeInputLabel }
    ]
  }
];
const demoCommands = commandSections.flatMap((section) => section.commands.map((command) => ({ ...command, section: section.title })));
const defaultCommand = demoCommands[0];
const defaultCommandIndex = Math.max(0, demoCommands.findIndex(({ command }) => command === defaultCommand.command));
const nextCommand = demoCommands[(defaultCommandIndex + 1) % demoCommands.length] || defaultCommand;
const commandCopyParagraphs = [m.commands.copy, m.commands.actionCopy].filter(Boolean);
---

<section class="section commands" id="commands" aria-labelledby="commands-title">
  <div class="section-inner">
    <div class="commands-layout">
      <div class="commands-copy walkthrough-clip-tag-host">
        <WalkthroughClipTag
          chapter="use-tab-commands"
          label={m.features.walkthroughClipCta}
          title={m.features.walkthroughKeyPointCommands}
        />
        <span class="section-icon" data-symbol="terminal" aria-hidden="true">
          <Icon name="terminal" />
        </span>
        <h2 id="commands-title">{m.commands.title}</h2>
        <div class="commands-copy-body">
          {commandCopyParagraphs.map((copy) => <p class="section-copy">{copy}</p>)}
        </div>
      </div>

      <div class="command-showcase" data-command-demo>
        <div class="command-playground">
          <div class="command-menu" id="command-demo-menu" data-command-menu role="listbox" aria-label={m.commands.title}>
            {demoCommands.map((item) => (
              <button
                class:list={['command-menu-item', item.command === defaultCommand.command && 'is-active']}
                type="button"
                role="option"
                aria-selected={item.command === defaultCommand.command ? 'true' : 'false'}
                data-command-option
                data-command-value={item.command}
                data-command-template={item.template}
                tabindex={item.command === defaultCommand.command ? '0' : '-1'}
              >
                <span class="command-menu-command">
                  <code>{item.command}</code>
                  {item.aliases.slice(0, 2).map((alias) => <code class="command-alias-code">{alias}</code>)}
                </span>
                <span class="command-menu-copy">
                  <strong>{item.section}</strong>
                  <span>{item.description}</span>
                </span>
              </button>
            ))}
          </div>
          <div class="command-composer-row">
            <div class="command-composer">
              <div class="command-input-wrap" data-command-input-wrap style={`--command-input-text-width: ${Math.min(Math.max(defaultCommand.template.length + 1, 9), 34)}ch`}>
                <span class="command-input-main">
                  <input
                    id="command-demo-input"
                    data-command-input
                    value={defaultCommand.template}
                    placeholder={defaultCommand.template}
                    autocomplete="off"
                    spellcheck="false"
                    aria-label={m.commands.title}
                    readonly
                    tabindex="-1"
                  >
                  <span class="command-input-cycle" data-command-cycle aria-hidden="true">
                    <span class="command-cycle-row" data-command-cycle-current>
                      <span class="command-cycle-template" data-command-cycle-current-text>{defaultCommand.template}</span>
                      <span class="command-tab-hint">
                        <span class="command-tab-plus" aria-hidden="true">+</span>
                        <svg class="command-tab-icon" viewBox="0 0 115 58" fill="none" aria-label="Tab" role="img">
                          <rect width="115" height="58" rx="13" fill="#3E3E3E"></rect>
                          <path d="M36.1227 44.8847C35.4918 45.5114 34.418 45.0645 34.418 44.1752V31.4029C34.418 30.5136 35.4918 30.0667 36.1227 30.6935L42.5514 37.0796C42.9451 37.4707 42.9451 38.1075 42.5514 38.4985L36.1227 44.8847ZM17 39.5664C16.4477 39.5664 16 39.1187 16 38.5664V36.9727C16 36.4204 16.4477 35.9727 17 35.9727H36.4062C36.9585 35.9727 37.4062 36.4204 37.4062 36.9727V38.5664C37.4062 39.1187 36.9585 39.5664 36.4062 39.5664H17ZM47.1172 46.5391C46.5649 46.5391 46.1172 46.0913 46.1172 45.5391V30C46.1172 29.4477 46.5649 29 47.1172 29H48.6914C49.2437 29 49.6914 29.4477 49.6914 30V45.5391C49.6914 46.0913 49.2437 46.5391 48.6914 46.5391H47.1172Z" fill="white"></path>
                        </svg>
                      </span>
                    </span>
                    <span class="command-cycle-row" data-command-cycle-next>
                      <span class="command-cycle-template" data-command-cycle-next-text>{nextCommand.template}</span>
                      <span class="command-tab-hint">
                        <span class="command-tab-plus" aria-hidden="true">+</span>
                        <svg class="command-tab-icon" viewBox="0 0 115 58" fill="none" aria-label="Tab" role="img">
                          <rect width="115" height="58" rx="13" fill="#3E3E3E"></rect>
                          <path d="M36.1227 44.8847C35.4918 45.5114 34.418 45.0645 34.418 44.1752V31.4029C34.418 30.5136 35.4918 30.0667 36.1227 30.6935L42.5514 37.0796C42.9451 37.4707 42.9451 38.1075 42.5514 38.4985L36.1227 44.8847ZM17 39.5664C16.4477 39.5664 16 39.1187 16 38.5664V36.9727C16 36.4204 16.4477 35.9727 17 35.9727H36.4062C36.9585 35.9727 37.4062 36.4204 37.4062 36.9727V38.5664C37.4062 39.1187 36.9585 39.5664 36.4062 39.5664H17ZM47.1172 46.5391C46.5649 46.5391 46.1172 46.0913 46.1172 45.5391V30C46.1172 29.4477 46.5649 29 47.1172 29H48.6914C49.2437 29 49.6914 29.4477 49.6914 30V45.5391C49.6914 46.0913 49.2437 46.5391 48.6914 46.5391H47.1172Z" fill="white"></path>
                        </svg>
                      </span>
                    </span>
                  </span>
                </span>
              </div>
              <span class="command-input-actions" aria-hidden="true">
                <span class="command-input-action">
                  <svg viewBox="0 -960 960 960" focusable="false">
                    <path d="M362-401 188-228q-11 11-27.5 11.5T132-228q-11-11-11-28t11-28l174-174q-35-35-63.5-80T190-640h84q20 39 40 68t48 58q33-33 68.5-92.5T484-720H80q-17 0-28.5-11.5T40-760q0-17 11.5-28.5T80-800h240v-40q0-17 11.5-28.5T360-880q17 0 28.5 11.5T400-840v40h240q17 0 28.5 11.5T680-760q0 17-11.5 28.5T640-720h-76q-21 72-63 148t-83 116l96 98-30 82-122-125Z"></path>
                    <path d="m603-202-34 97q-4 11-14 18t-22 7q-20 0-32.5-16.5T496-133l152-402q5-11 15-18t22-7h30q12 0 22 7t15 18l152 403q8 19-4 35.5T868-80q-13 0-22.5-7T831-106l-34-96H603Zm25-70h144l-72-204-72 204Z"></path>
                  </svg>
                </span>
                <span class="command-input-action">
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M12 1C5.925 1 1 5.925 1 12s4.925 11 11 11 11-4.925 11-11S18.075 1 12 1Zm0 2a9 9 0 110 18.001A9 9 0 0112 3ZM9 8.5a1.5 1.5 0 100 3 1.5 1.5 0 000-3Zm6 0a1.5 1.5 0 100 3 1.5 1.5 0 000-3Zm-.525 5.475a3.5 3.5 0 01-4.95 0 1 1 0 10-1.414 1.414 5.5 5.5 0 007.778 0 1 1 0 00-1.414-1.414Z"></path>
                  </svg>
                </span>
              </span>
            </div>
            <span class="command-send-button" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="m21.5 12.867 1.496-.865-1.495-.866L4.65 1.38c-1.513-.876-3.26.7-2.544 2.295l3.743 8.327-3.743 8.325c-.717 1.594 1.03 3.172 2.543 2.296l16.85-9.756ZM7.59 11 4.185 3.421l13.089 7.58H7.59Zm.003 2h9.688L4.185 20.581l3.408-7.58Z"></path>
              </svg>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
