---
import type { CollectionEntry } from 'astro:content';
import { getBlogPostPath } from '../../data/blog';
import type { Locale } from '../../data/locales';
import type { Messages } from '../../data/site';
import Commands from './commands.astro';
import Features from './features.astro';
import Hero from './hero.astro';
import Install from './install.astro';
import LatestUpdates from './latest-updates.astro';
import Playground from './playground.astro';
import Privacy from './privacy.astro';
import Screenshots from './screenshots.astro';

const { locale, messages, posts, rootPrefix } = Astro.props as {
  locale: Locale;
  messages: Messages;
  posts: CollectionEntry<'blog'>[];
  rootPrefix: string;
};
const playgroundPost = posts.find((post) => post.data.translationKey === 'introducing-playground-tiny-games-for-live-chat-breaks');
if (!playgroundPost) {
  throw new Error('Missing required Playground blog post.');
}
const playgroundPostPath = getBlogPostPath(playgroundPost);
const gamePostPaths = {
  chess: playgroundPostPath,
  trivia: getRequiredBlogPostPath('new-in-0-14-0-help-a-friend-trivia'),
  wild: getRequiredBlogPostPath('the-wild-wild-chat-coming-to-chat-enhancer-0-15-0')
};

function getRequiredBlogPostPath(translationKey: string): string {
  const post = posts.find((candidate) => candidate.data.translationKey === translationKey);
  if (!post) {
    throw new Error(`Missing required blog post: ${translationKey}`);
  }

  return getBlogPostPath(post);
}
---

<Hero messages={messages} rootPrefix={rootPrefix} />
<Features messages={messages} />
<Playground messages={messages} playgroundPostPath={playgroundPostPath} gamePostPaths={gamePostPaths} rootPrefix={rootPrefix} />
<Screenshots messages={messages} rootPrefix={rootPrefix} />
<Install locale={locale} messages={messages} rootPrefix={rootPrefix} />
<Privacy locale={locale} messages={messages} />
<Commands messages={messages} />
<LatestUpdates locale={locale} posts={posts} />
