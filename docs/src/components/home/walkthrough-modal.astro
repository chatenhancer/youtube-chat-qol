---
import type { Messages } from '../../data/site';
import { walkthroughChapters } from '../../data/walkthrough';

const { messages: m } = Astro.props as { messages: Messages };
const walkthroughKeyPoints = walkthroughChapters.map((chapter) => ({
  ...chapter,
  label: m.features[chapter.labelKey]
}));
---

<dialog class="walkthrough-modal" id="walkthrough" data-walkthrough-modal aria-labelledby="walkthrough-modal-title">
  <div class="walkthrough-modal-panel">
    <div class="walkthrough-modal-heading">
      <h2 id="walkthrough-modal-title">{m.features.walkthroughModalTitle}</h2>
      <button class="walkthrough-modal-close" type="button" data-walkthrough-close aria-label={m.features.walkthroughClose}>
        <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
          <path d="M6.4 5.05 12 10.65l5.6-5.6 1.35 1.35-5.6 5.6 5.6 5.6-1.35 1.35-5.6-5.6-5.6 5.6-1.35-1.35 5.6-5.6-5.6-5.6 1.35-1.35Z"></path>
        </svg>
      </button>
    </div>
    <aside class="walkthrough-key-points" data-walkthrough-key-points aria-label={m.features.walkthroughKeyPointsAria}>
      <button
        class="walkthrough-modal-time"
        type="button"
        data-walkthrough-time
        data-walkthrough-time-toggle
        aria-controls="walkthrough-key-point-panel"
        aria-expanded="false"
      >
        <span class="walkthrough-modal-time-label" data-walkthrough-time-label>0:00 / 0:00</span>
        <span class="walkthrough-modal-time-chevron" aria-hidden="true"></span>
      </button>
      <div class="walkthrough-key-point-panel" id="walkthrough-key-point-panel">
        <div class="walkthrough-key-point-list" data-walkthrough-key-point-list>
          <div class="walkthrough-key-point-track" data-walkthrough-key-point-track>
            {walkthroughKeyPoints.map((point) => (
              <a
                class="walkthrough-key-point"
                id={`walkthrough-${point.name}`}
                href={`#walkthrough-${point.name}`}
                data-walkthrough-chapter={point.name}
                data-walkthrough-seek={String(point.seconds)}
                aria-label={`${point.time} ${point.label}`}
              >
                <span class="walkthrough-key-point-time">{point.time}</span>
                <span class="walkthrough-key-point-label">{point.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </aside>
    <div class="walkthrough-video-frame">
      <video class="walkthrough-video" data-walkthrough-video playsinline loop preload="none" tabindex="0"></video>
      <span class="walkthrough-video-feedback" data-walkthrough-feedback aria-hidden="true">
        <svg class="walkthrough-video-feedback-icon walkthrough-video-feedback-play" viewBox="0 -960 960 960" focusable="false">
          <path d="M320-273v-414q0-17 12-28.5t28-11.5q5 0 10.5 1.5T381-721l326 207q9 6 13.5 15t4.5 19q0 10-4.5 19T707-446L381-239q-5 3-10.5 4.5T360-233q-16 0-28-11.5T320-273Z"></path>
        </svg>
        <svg class="walkthrough-video-feedback-icon walkthrough-video-feedback-pause" viewBox="0 -960 960 960" focusable="false">
          <path d="M640-200q-33 0-56.5-23.5T560-280v-400q0-33 23.5-56.5T640-760q33 0 56.5 23.5T720-680v400q0 33-23.5 56.5T640-200Zm-320 0q-33 0-56.5-23.5T240-280v-400q0-33 23.5-56.5T320-760q33 0 56.5 23.5T400-680v400q0 33-23.5 56.5T320-200Z"></path>
        </svg>
      </span>
    </div>
  </div>
</dialog>
