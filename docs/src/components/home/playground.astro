---
import Icon from '../common/icon.astro';
import type { Messages } from '../../data/site';

interface GamePostPaths {
  chess: string;
  stickAround: string;
  trivia: string;
  wild: string;
}

const { messages: m, playgroundLearnMorePath, gamePostPaths, rootPrefix } = Astro.props as {
  messages: Messages;
  playgroundLearnMorePath: string;
  gamePostPaths: GamePostPaths;
  rootPrefix: string;
};

const playgroundGames = [
  {
    alt: 'The Wild Wild Chat',
    className: 'playground-game-logo-wild',
    href: gamePostPaths.wild,
    src: 'assets/playground/wild-wild-chat-logo.webp'
  },
  {
    alt: "Stick Around!: It's Raining Bubbles",
    className: 'playground-game-logo-stick-around',
    href: gamePostPaths.stickAround,
    src: 'assets/playground/stick-around-logo.webp'
  },
  {
    alt: 'HELP-A-FRIEND! Trivia',
    className: 'playground-game-logo-trivia',
    href: gamePostPaths.trivia,
    src: 'assets/playground/replay-trivia-logo.png'
  }
];
---

<section class="playground-section" id="playground" aria-labelledby="playground-title">
  <div class="playground-inner">
    <div class="playground-copy">
      <div class="playground-heading-row">
        <span class="playground-section-icon" aria-hidden="true">
          <Icon name="playground" />
        </span>
        <span class="playground-eyebrow">{m.playground.eyebrow}</span>
        <span class="playground-beta-badge">Beta</span>
      </div>
      <h2 id="playground-title" set:html={m.playground.title}></h2>
      <p>{m.playground.copy}</p>
      <div class="playground-actions">
        <a class="button button-primary" href="#install">
          <span class="button-icon" data-symbol="extension" aria-hidden="true">
            <Icon name="extension" />
          </span>
          {m.playground.primaryCta}
        </a>
        <a class="button playground-link" href={playgroundLearnMorePath}>
          <span class="button-icon" data-symbol="ads_click" aria-hidden="true">
            <Icon name="ads_click" />
          </span>
          {m.playground.secondaryCta}
        </a>
      </div>
      <p class="playground-note">{m.playground.note}</p>
      <div class="playground-game-logos" aria-label="Playground games">
        <a class="playground-game-logo-link" href={gamePostPaths.chess} aria-label="Read about Chess">
          <span class="playground-game-logo playground-game-logo-chess" aria-hidden="true">
            <span class="playground-game-logo-chess-piece" aria-hidden="true" style={`background-image: url('${rootPrefix}assets/playground/chess-white-pieces.png')`}></span>
          </span>
        </a>
        {playgroundGames.map((game) => (
          <a class="playground-game-logo-link" href={game.href} aria-label={`Read about ${game.alt}`}>
            <img class={`playground-game-logo ${game.className}`} src={`${rootPrefix}${game.src}`} alt="" loading="lazy" decoding="async">
          </a>
        ))}
      </div>
    </div>
    <figure class="playground-preview">
      <img class="playground-preview-card playground-preview-card-back playground-preview-card-back-right" src={`${rootPrefix}assets/playground/trivia-preview.png`} alt="" loading="lazy" decoding="async" aria-hidden="true">
      <img class="playground-preview-card playground-preview-card-back playground-preview-card-back-left" src={`${rootPrefix}assets/playground/trivia-results-preview.png`} alt="" loading="lazy" decoding="async" aria-hidden="true">
      <img class="playground-preview-card playground-preview-card-main" src={`${rootPrefix}assets/playground/chess-preview.png`} alt={m.playground.imageAlt} loading="lazy" decoding="async">
    </figure>
  </div>
</section>
