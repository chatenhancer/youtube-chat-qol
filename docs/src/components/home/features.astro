---
import Icon from '../common/icon.astro';
import WalkthroughClipTag from '../common/walkthrough-clip-tag.astro';
import type { Messages } from '../../data/site';

const { messages: m } = Astro.props as { messages: Messages };
const features = [
  {
    body: m.features.translationBody,
    chapter: 'translate-live-chat',
    clipTitle: m.features.walkthroughKeyPointTranslation,
    icon: 'translate',
    title: m.features.translationTitle
  },
  {
    body: m.features.mentionBody,
    chapter: 'mention-and-quote',
    clipTitle: m.features.walkthroughKeyPointMentions,
    icon: 'alternate_email',
    title: m.features.mentionTitle
  },
  {
    body: m.features.contextBody,
    chapter: 'review-user-profiles',
    clipTitle: m.features.walkthroughKeyPointUserCards,
    icon: 'person_search',
    title: m.features.contextTitle
  },
  {
    body: m.features.inboxBody,
    chapter: 'never-miss-messages',
    clipTitle: m.features.walkthroughKeyPointInbox,
    icon: 'inbox',
    title: m.features.inboxTitle
  },
  {
    body: m.features.emojisBody,
    chapter: 'keep-emojis-close',
    clipTitle: m.features.walkthroughKeyPointEmojis,
    icon: 'mood',
    title: m.features.emojisTitle
  },
  {
    body: m.features.commandsBody,
    chapter: 'use-tab-commands',
    clipTitle: m.features.walkthroughKeyPointCommands,
    icon: 'terminal',
    title: m.features.commandsTitle
  }
] as const;
---

<section class="section feature-band" id="features" aria-labelledby="features-title">
  <div class="section-inner feature-inner">
    <span class="section-icon section-title-icon" data-symbol="startup-effect" aria-hidden="true">
      <svg class="option-icon startup-effect-icon" viewBox="0 -960 960 960" focusable="false">
        <path class="startup-sparkle startup-sparkle-small-start" d="m306-120-44-92-102-44 102-44 44-92 44 92 102 44-102 44-44 92Z"></path>
        <path class="startup-sparkle startup-sparkle-large" d="m684-200-76-160-168-76 168-76 76-160 76 160 168 76-168 76-76 160Z"></path>
        <path class="startup-sparkle startup-sparkle-small-end" d="m306-568-44-92-102-44 102-44 44-92 44 92 102 44-102 44-44 92Z"></path>
      </svg>
    </span>
    <h2 id="features-title" set:html={m.features.title}></h2>
    <div class="feature-grid">
      {features.map(({ body, chapter, clipTitle, icon, title }) => (
        <article class="feature walkthrough-clip-tag-host">
          <WalkthroughClipTag
            chapter={chapter}
            label={m.features.walkthroughClipCta}
            title={clipTitle}
          />
          <span class:list={['feature-icon', icon === 'inbox' && 'feature-icon-inbox']} data-symbol={icon} aria-hidden="true">
            <Icon name={icon} viewBox={icon === 'inbox' ? '0 0 24 24' : '0 -960 960 960'} />
            {icon === 'inbox' && <span class="feature-icon-badge">1</span>}
          </span>
          <h3>{title}</h3>
          <p>{body}</p>
          {icon === 'terminal' && <a class="feature-link" href="#commands">{m.features.commandsLink}</a>}
        </article>
      ))}
    </div>
    <div class="feature-walkthrough-mount" hidden data-walkthrough-cta>
      <button class="feature-walkthrough" type="button" data-walkthrough-open aria-label={m.features.walkthroughCta}>
        <span class="feature-walkthrough-copy">
          <strong>{m.features.walkthroughTitle}</strong>
          <span>{m.features.walkthroughBody}</span>
        </span>
        <span class="feature-walkthrough-action" aria-hidden="true">
          <svg class="feature-walkthrough-play" viewBox="0 0 64 48" focusable="false" aria-hidden="true">
            <path
              class="feature-walkthrough-play-bg"
              d="M32 2 L41.39 2.05 L45.25 2.21 L48.16 2.48 L50.56 2.85 L52.6 3.34 L54.36 3.94 L55.89 4.66 L57.23 5.5 L58.38 6.48 L59.36 7.6 L60.17 8.9 L60.84 10.39 L61.35 12.15 L61.71 14.28 L61.93 17.11 L62 24 L61.93 30.89 L61.71 33.72 L61.35 35.85 L60.84 37.61 L60.17 39.1 L59.36 40.4 L58.38 41.52 L57.23 42.5 L55.89 43.34 L54.36 44.06 L52.6 44.66 L50.56 45.15 L48.16 45.52 L45.25 45.79 L41.39 45.95 L32 46 L22.61 45.95 L18.75 45.79 L15.84 45.52 L13.44 45.15 L11.4 44.66 L9.64 44.06 L8.11 43.34 L6.77 42.5 L5.62 41.52 L4.64 40.4 L3.83 39.1 L3.16 37.61 L2.65 35.85 L2.29 33.72 L2.07 30.89 L2 24 L2.07 17.11 L2.29 14.28 L2.65 12.15 L3.16 10.39 L3.83 8.9 L4.64 7.6 L5.62 6.48 L6.77 5.5 L8.11 4.66 L9.64 3.94 L11.4 3.34 L13.44 2.85 L15.84 2.48 L18.75 2.21 L22.61 2.05 Z"
            />
            <path class="feature-walkthrough-play-symbol" transform="translate(1.6 0)" d="M24.3 16.8v14.4c0 1.3 1.5 2.1 2.6 1.4l12-7.2c1.1-.7 1.1-2.1 0-2.8l-12-7.2c-1.1-.7-2.6.1-2.6 1.4Z" />
          </svg>
        </span>
      </button>
    </div>
  </div>
</section>
