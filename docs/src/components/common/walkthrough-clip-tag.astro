---
import Icon from './icon.astro';
import { getWalkthroughClip } from '../../data/walkthrough';
import type { WalkthroughChapterName } from '../../data/walkthrough';

const { chapter, label, title } = Astro.props as {
  chapter: WalkthroughChapterName;
  label: string;
  title: string;
};
const clip = getWalkthroughClip(chapter);
---

<button
  class="walkthrough-clip-tag"
  type="button"
  data-walkthrough-clip-open
  data-walkthrough-clip-chapter={chapter}
  data-walkthrough-clip-start={clip.startSeconds}
  data-walkthrough-clip-end={clip.endSeconds}
  data-walkthrough-clip-title={title}
  aria-label={[label, title].join(': ')}
>
  <Icon class="walkthrough-clip-tag-icon" name="play_circle" />
  <span>{label}</span>
</button>
