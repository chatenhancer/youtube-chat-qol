---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BlogLayout from '../../layouts/blog-layout.astro';
import { getBlogCoverVideoUrl } from '../../data/blog-media';
import { getMessages } from '../../data/locales';
import { site } from '../../data/site';

const messages = getMessages('en');
const posts = (await getCollection('blog')).sort((first, second) => second.data.date.valueOf() - first.data.date.valueOf());
const formatter = new Intl.DateTimeFormat('en', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
const BLOG_CARD_IMAGE_WIDTH = 1280;
---

<BlogLayout
  canonicalUrl={`${site.url}/blog/`}
  description="Updates, release notes, and development notes for Chat Enhancer for YouTube."
  messages={messages}
  title="Updates"
>
  <section class="blog-archive">
    <p class="eyebrow">Updates</p>
    <h1>Latest notes</h1>
    <p class="blog-archive-copy">Release notes and project updates for Chat Enhancer for YouTube.</p>
    <div class="blog-archive-grid">
      {posts.map((post) => {
        const coverVideoUrl = getBlogCoverVideoUrl(post.data.slug, post.data.video);

        return (
          <a class="latest-update-card blog-archive-card" href={`/blog/${post.data.slug}/`}>
            <span class="latest-update-media">
              {post.data.image && (coverVideoUrl ? (
                <video src={coverVideoUrl} poster={post.data.image.src} autoplay muted loop playsinline preload="metadata" aria-hidden="true" />
              ) : (
                <Image src={post.data.image} alt="" width={BLOG_CARD_IMAGE_WIDTH} loading="lazy" decoding="async" />
              ))}
            </span>
            <span class="latest-update-copy">
              <time datetime={post.data.date.toISOString().slice(0, 10)}>{formatter.format(post.data.date)}</time>
              <strong>{post.data.title}</strong>
              <span>{post.data.description}</span>
            </span>
          </a>
        );
      })}
    </div>
  </section>
</BlogLayout>
