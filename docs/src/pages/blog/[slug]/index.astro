---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import RelatedPosts from '../../../components/blog/related-posts.astro';
import BlogLayout from '../../../layouts/blog-layout.astro';
import type { BlogPost } from '../../../data/blog';
import {
  getBlogEntryFolder,
  getBlogIndexPath,
  getBlogPostAlternateLinks,
  getBlogPostLanguageUrls,
  getBlogPostUrl,
  getPostLocale
} from '../../../data/blog';
import { getBlogCoverVideoUrl } from '../../../data/blog-media';
import { getMessages, htmlLangFor } from '../../../data/locales';
import { site } from '../../../data/site';

interface Props {
  allPosts: BlogPost[];
  post: BlogPost;
}

export async function getStaticPaths() {
  const posts: BlogPost[] = await getCollection('blog');
  return posts
    .filter((post) => post.data.locale === 'en')
    .map((post) => ({
      params: { slug: post.data.slug },
      props: { allPosts: posts, post }
    }));
}

const { allPosts, post } = Astro.props as Props;
const { Content } = await render(post);
const locale = getPostLocale(post);
const messages = getMessages(locale);
const blog = messages.blog;
const formatter = new Intl.DateTimeFormat(htmlLangFor(locale), {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
const canonicalUrl = getBlogPostUrl(post);
const coverUrl = post.data.image ? new URL(post.data.image.src, site.url).toString() : undefined;
const coverVideoUrl = getBlogCoverVideoUrl(getBlogEntryFolder(post), post.data.video);
const postDate = post.data.date.toISOString();
const blogPostStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  url: canonicalUrl,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl
  },
  datePublished: postDate,
  dateModified: postDate,
  inLanguage: htmlLangFor(locale),
  ...(coverUrl ? { image: [coverUrl] } : {}),
  author: {
    '@type': 'Organization',
    name: site.title,
    url: site.url
  },
  publisher: {
    '@type': 'Organization',
    name: site.title,
    logo: {
      '@type': 'ImageObject',
      url: `${site.url}/assets/icons/icon-128.png`
    }
  },
  isPartOf: {
    '@type': 'Blog',
    name: `${site.title} ${blog.updates}`,
    url: `${site.url}${getBlogIndexPath(locale)}`
  }
};

const titleHtml = decorateBrandMentions(post.data.title);
const descriptionHtml = decorateBrandMentions(post.data.description);

function decorateBrandMentions(value: string): string {
  return escapeHtml(value).replaceAll(
    'Chat Enhancer',
    '<span class="blog-brand-inline"><img src="/assets/icons/icon.svg" alt="" aria-hidden="true">Chat Enhancer</span>'
  );
}

function escapeHtml(value: string): string {
  return value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll('\'', '&#39;');
}
---

<BlogLayout
  canonicalUrl={canonicalUrl}
  description={post.data.description}
  image={coverUrl}
  alternateLinks={getBlogPostAlternateLinks(allPosts, post)}
  languageUrls={getBlogPostLanguageUrls(allPosts, post)}
  locale={locale}
  messages={messages}
  ogType="article"
  rootPrefix="../../"
  structuredData={blogPostStructuredData}
  title={post.data.title}
  xDefaultUrl={getBlogPostUrl(post)}
>
  <article class="blog-post blog-post-page">
    <header class="blog-post-header">
      <a class="feature-link" href={getBlogIndexPath(locale)}>{blog.backToUpdates}</a>
      <time datetime={post.data.date.toISOString().slice(0, 10)}>{formatter.format(post.data.date)}</time>
      <h1 set:html={titleHtml} />
      <p set:html={descriptionHtml} />
    </header>
    {post.data.image && (
      <figure class="blog-post-cover">
        {coverVideoUrl ? (
          <video src={coverVideoUrl} poster={post.data.image.src} autoplay muted loop playsinline preload="metadata" aria-hidden="true" />
        ) : (
          <Image src={post.data.image} alt="" loading="eager" decoding="async" />
        )}
      </figure>
    )}
    <div class="blog-post-body">
      <Content />
    </div>
    <RelatedPosts allPosts={allPosts} locale={locale} post={post} />
    <a class="blog-post-editor-credit" href="https://lepapier.app/" target="_blank" rel="noopener noreferrer">
      <img src="/assets/lepapier.svg" alt="" width="524" height="584" loading="lazy" decoding="async">
      <span>{blog.editorCredit}</span>
    </a>
  </article>
</BlogLayout>
