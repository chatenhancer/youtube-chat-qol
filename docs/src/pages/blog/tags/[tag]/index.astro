---
import { getCollection } from 'astro:content';
import PostCardGrid from '../../../../components/blog/post-card-grid.astro';
import BlogLayout from '../../../../layouts/blog-layout.astro';
import type { BlogPost, BlogTagArchive } from '../../../../data/blog';
import {
  getBlogIndexPath,
  getBlogTagAlternateLinks,
  getBlogTagArchives,
  getBlogTagLanguageUrls,
  getBlogTagUrl
} from '../../../../data/blog';
import { getMessages } from '../../../../data/locales';
import { site } from '../../../../data/site';

interface Props {
  allPosts: BlogPost[];
  archive: BlogTagArchive;
}

export async function getStaticPaths() {
  const posts: BlogPost[] = await getCollection('blog');
  return getBlogTagArchives(posts, 'en').map((archive) => ({
    params: { tag: archive.tagSlug },
    props: { allPosts: posts, archive }
  }));
}

const locale = 'en';
const { allPosts, archive } = Astro.props as Props;
const messages = getMessages(locale);
const blog = messages.blog;
const pageTitle = `#${archive.tag}`;
const pageDescription = `${pageTitle} - ${blog.archiveCopy}`;
const canonicalUrl = getBlogTagUrl(locale, archive.tag);
const latestPostDate = archive.posts[0]?.data.date.toISOString();
const blogTagStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  inLanguage: 'en',
  ...(latestPostDate ? { dateModified: latestPostDate } : {}),
  isPartOf: {
    '@type': 'Blog',
    name: `${site.title} ${blog.updates}`,
    url: `${site.url}${getBlogIndexPath(locale)}`
  }
};
---

<BlogLayout
  alternateLinks={getBlogTagAlternateLinks(allPosts, archive.tag)}
  canonicalUrl={canonicalUrl}
  description={pageDescription}
  languageUrls={getBlogTagLanguageUrls(allPosts, archive.tag)}
  locale={locale}
  messages={messages}
  rootPrefix="../../../"
  structuredData={blogTagStructuredData}
  title={pageTitle}
  xDefaultUrl={getBlogTagUrl(locale, archive.tag)}
>
  <section class="blog-archive blog-tag-archive">
    <a class="feature-link" href={getBlogIndexPath(locale)}>{blog.backToUpdates}</a>
    <h1>{pageTitle}</h1>
    <p class="blog-archive-copy">{blog.archiveCopy}</p>
    <PostCardGrid locale={locale} posts={archive.posts} />
    <a class="blog-post-editor-credit blog-archive-editor-credit" href="https://lepapier.app/" target="_blank" rel="noopener noreferrer">
      <img src="/assets/lepapier.svg" alt="" width="524" height="584" loading="lazy" decoding="async">
      <span>{blog.editorCredit}</span>
    </a>
  </section>
</BlogLayout>
