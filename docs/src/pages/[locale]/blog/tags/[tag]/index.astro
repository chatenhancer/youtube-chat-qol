---
import { getCollection } from 'astro:content';
import BackToUpdatesLink from '../../../../../components/blog/back-to-updates-link.astro';
import PostCardGrid from '../../../../../components/blog/post-card-grid.astro';
import BlogLayout from '../../../../../layouts/blog-layout.astro';
import type { BlogPost, BlogTagArchive } from '../../../../../data/blog';
import {
  getBlogIndexPath,
  getBlogTagAlternateLinks,
  getBlogTagArchives,
  getBlogTagLanguageUrls,
  getBlogTagUrl
} from '../../../../../data/blog';
import { getMessages, htmlLangFor, localeMeta, locales } from '../../../../../data/locales';
import type { Locale } from '../../../../../data/locales';
import { site } from '../../../../../data/site';

interface Props {
  allPosts: BlogPost[];
  archive: BlogTagArchive;
  resolvedLocale: Locale;
}

export async function getStaticPaths() {
  const posts: BlogPost[] = await getCollection('blog');
  return locales
    .filter((locale) => locale !== 'en')
    .flatMap((locale) =>
      getBlogTagArchives(posts, locale).map((archive) => ({
        params: {
          locale: localeMeta[locale].path,
          tag: archive.tagSlug
        },
        props: { allPosts: posts, archive, resolvedLocale: locale }
      }))
    );
}

const { allPosts, archive, resolvedLocale: locale } = Astro.props as Props;
const messages = getMessages(locale);
const blog = messages.blog;
const pageTitle = `#${archive.tag}`;
const pageDescription = `${pageTitle} - ${blog.archiveCopy}`;
const canonicalUrl = getBlogTagUrl(locale, archive.tag);
const languageUrls = getBlogTagLanguageUrls(allPosts, archive.tag);
const latestPostDate = archive.posts[0]?.data.date.toISOString();
const blogTagStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  inLanguage: htmlLangFor(locale),
  ...(latestPostDate ? { dateModified: latestPostDate } : {}),
  isPartOf: {
    '@type': 'Blog',
    name: `${site.title} ${blog.updates}`,
    url: `${site.url}${getBlogIndexPath(locale)}`
  }
};
---

<BlogLayout
  alternateLinks={getBlogTagAlternateLinks(allPosts, archive.tag)}
  canonicalUrl={canonicalUrl}
  description={pageDescription}
  languageUrls={languageUrls}
  locale={locale}
  messages={messages}
  rootPrefix="../../../../"
  structuredData={blogTagStructuredData}
  title={pageTitle}
  xDefaultUrl={languageUrls.en ? getBlogTagUrl('en', archive.tag) : null}
>
  <section class="blog-archive blog-tag-archive">
    <BackToUpdatesLink href={getBlogIndexPath(locale)} label={blog.backToUpdates} />
    <h1>{pageTitle}</h1>
    <p class="blog-archive-copy">{blog.archiveCopy}</p>
    <PostCardGrid locale={locale} posts={archive.posts} />
    <a class="blog-post-editor-credit blog-archive-editor-credit" href="https://lepapier.app/" target="_blank" rel="noopener noreferrer">
      <img src="/assets/lepapier.svg" alt="" width="524" height="584" loading="lazy" decoding="async">
      <span>{blog.editorCredit}</span>
    </a>
  </section>
</BlogLayout>
