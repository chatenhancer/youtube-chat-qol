---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BlogLayout from '../../../layouts/blog-layout.astro';
import {
  getBlogEntryFolder,
  getBlogIndexAlternateLinks,
  getBlogIndexLanguageUrls,
  getBlogIndexUrl,
  getBlogMessages,
  getBlogPostPath,
  getLocalizedBlogPosts
} from '../../../data/blog';
import { getBlogCoverVideoUrl } from '../../../data/blog-media';
import { getLocaleFromPath, getMessages, htmlLangFor, localeMeta, locales } from '../../../data/locales';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== 'en')
    .map((locale) => ({
      params: { locale: localeMeta[locale].path },
      props: { resolvedLocale: locale }
    }));
}

const locale = Astro.props.resolvedLocale ?? getLocaleFromPath(Astro.params.locale || '');
const messages = getMessages(locale);
const blog = getBlogMessages(locale);
const posts = getLocalizedBlogPosts(await getCollection('blog'), locale);
const formatter = new Intl.DateTimeFormat(htmlLangFor(locale), {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
const BLOG_CARD_IMAGE_WIDTH = 1280;
---

<BlogLayout
  alternateLinks={getBlogIndexAlternateLinks()}
  canonicalUrl={getBlogIndexUrl(locale)}
  description={blog.archiveCopy}
  languageUrls={getBlogIndexLanguageUrls()}
  locale={locale}
  messages={messages}
  rootPrefix="../../"
  title={blog.updates}
  xDefaultUrl={getBlogIndexUrl('en')}
>
  <section class="blog-archive">
    <p class="eyebrow">{blog.updates}</p>
    <h1>{blog.latestNotes}</h1>
    <p class="blog-archive-copy">{blog.archiveCopy}</p>
    <div class="blog-archive-grid">
      {posts.map((post) => {
        const coverVideoUrl = getBlogCoverVideoUrl(getBlogEntryFolder(post), post.data.video);

        return (
          <a class="latest-update-card blog-archive-card" href={getBlogPostPath(post)}>
            <span class="latest-update-media">
              {post.data.image && (coverVideoUrl ? (
                <video src={coverVideoUrl} poster={post.data.image.src} autoplay muted loop playsinline preload="metadata" aria-hidden="true" />
              ) : (
                <Image src={post.data.image} alt="" width={BLOG_CARD_IMAGE_WIDTH} loading="lazy" decoding="async" />
              ))}
            </span>
            <span class="latest-update-copy">
              <time datetime={post.data.date.toISOString().slice(0, 10)}>{formatter.format(post.data.date)}</time>
              <strong>{post.data.title}</strong>
              <span>{post.data.description}</span>
            </span>
          </a>
        );
      })}
    </div>
  </section>
</BlogLayout>
