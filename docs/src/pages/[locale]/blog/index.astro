---
import { getCollection } from 'astro:content';
import PostCardGrid from '../../../components/blog/post-card-grid.astro';
import BlogLayout from '../../../layouts/blog-layout.astro';
import {
  getBlogIndexAlternateLinks,
  getBlogIndexLanguageUrls,
  getBlogIndexUrl,
  getLocalizedBlogPosts
} from '../../../data/blog';
import { getLocaleFromPath, getMessages, localeMeta, locales } from '../../../data/locales';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== 'en')
    .map((locale) => ({
      params: { locale: localeMeta[locale].path },
      props: { resolvedLocale: locale }
    }));
}

const locale = Astro.props.resolvedLocale ?? getLocaleFromPath(Astro.params.locale || '');
const messages = getMessages(locale);
const blog = messages.blog;
const posts = getLocalizedBlogPosts(await getCollection('blog'), locale);
---

<BlogLayout
  alternateLinks={getBlogIndexAlternateLinks()}
  canonicalUrl={getBlogIndexUrl(locale)}
  description={blog.archiveCopy}
  languageUrls={getBlogIndexLanguageUrls()}
  locale={locale}
  messages={messages}
  rootPrefix="../../"
  title={blog.updates}
  xDefaultUrl={getBlogIndexUrl('en')}
>
  <section class="blog-archive">
    <p class="eyebrow">{blog.updates}</p>
    <h1>{blog.latestNotes}</h1>
    <p class="blog-archive-copy">{blog.archiveCopy}</p>
    <PostCardGrid locale={locale} posts={posts} />
    <a class="blog-post-editor-credit blog-archive-editor-credit" href="https://lepapier.app/" target="_blank" rel="noopener noreferrer">
      <img src="/assets/lepapier.svg" alt="" width="524" height="584" loading="lazy" decoding="async">
      <span>{blog.editorCredit}</span>
    </a>
  </section>
</BlogLayout>
