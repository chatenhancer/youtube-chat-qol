---
import { getCollection } from 'astro:content';
import HomeLayout from '../layouts/home-layout.astro';
import HomePage from '../components/home/home-page.astro';
import { getLocalizedBlogPosts } from '../data/blog';
import { getWalkthroughVideoUrl } from '../data/media';
import { getMessages } from '../data/locales';

const locale = 'en';
const messages = getMessages(locale);
const posts = getLocalizedBlogPosts(await getCollection('blog'), locale);
const walkthroughUrl = getWalkthroughVideoUrl(locale);
const clientConfig = {
  ...(walkthroughUrl ? { walkthrough: walkthroughUrl } : {})
};
---

<HomeLayout clientConfig={clientConfig} locale={locale} messages={messages} rootPrefix="">
  <HomePage locale={locale} messages={messages} posts={posts} rootPrefix="" />
</HomeLayout>
