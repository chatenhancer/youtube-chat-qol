---
import BaseLayout from './base-layout.astro';
import Footer from '../components/home/footer.astro';
import Header from '../components/home/header.astro';
import StoreVersionAlert from '../components/home/store-version-alert.astro';
import WalkthroughModal from '../components/home/walkthrough-modal.astro';
import type { Locale } from '../data/locales';
import type { Messages } from '../data/site';

const { clientConfig = {}, locale, messages, rootPrefix } = Astro.props as {
  clientConfig?: Record<string, unknown>;
  locale: Locale;
  messages: Messages;
  rootPrefix: string;
};
---

<BaseLayout clientConfig={clientConfig} locale={locale} messages={messages} rootPrefix={rootPrefix}>
  <Header locale={locale} messages={messages} />
  <StoreVersionAlert messages={messages} />
  <main id="top" data-pagefind-body>
    <slot />
  </main>
  <WalkthroughModal messages={messages} />
  <Footer locale={locale} messages={messages} />
</BaseLayout>
