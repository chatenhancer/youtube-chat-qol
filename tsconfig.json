{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "resolveJsonModule": true,
    "types": ["chrome", "node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "cloudflare/language-redirect/src/**/*.ts",
    "cloudflare/playground/src/**/*.ts",
    "src/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "playwright.perf.config.ts"
  ]
}
