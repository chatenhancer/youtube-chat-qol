{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "short_name": "__MSG_extensionShortName__",
  "version": "0.14.4",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "icons": {
    "16": "dist/extension-chrome/icons/icon-16.png",
    "32": "dist/extension-chrome/icons/icon-32.png",
    "48": "dist/extension-chrome/icons/icon-48.png",
    "128": "dist/extension-chrome/icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/live_chat*",
    "https://www.youtube.com/live_chat_replay*",
    "https://studio.youtube.com/live_chat*",
    "https://studio.youtube.com/live_chat_replay*",
    "https://playground.chatenhancer.com/*",
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "service_worker": "dist/extension-chrome/background.js"
  },
  "action": {
    "default_title": "__MSG_extensionName__",
    "default_popup": "dist/extension-chrome/popup.html",
    "default_icon": {
      "16": "dist/extension-chrome/icons/icon-inactive-16.png",
      "32": "dist/extension-chrome/icons/icon-inactive-32.png",
      "48": "dist/extension-chrome/icons/icon-inactive-48.png",
      "128": "dist/extension-chrome/icons/icon-inactive-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/live_chat*",
        "https://www.youtube.com/live_chat_replay*",
        "https://studio.youtube.com/live_chat*",
        "https://studio.youtube.com/live_chat_replay*"
      ],
      "js": ["dist/extension-chrome/content.js"],
      "css": ["dist/extension-chrome/content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "games/*/*.mp3",
        "games/*/*.png",
        "locales/*.json"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://studio.youtube.com/*"
      ]
    }
  ]
}
